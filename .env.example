# Copy to .env and fill in before running on a public server.
# Never commit .env.

# Required in production
SECRET_KEY=generate-a-long-random-string
GEMINI_API_KEY=your-gemini-api-key

# Session cookies over HTTPS (set when behind TLS)
SESSION_COOKIE_SECURE=true

# Registration: off by default so strangers cannot create accounts
REGISTRATION_ENABLED=false
# Optional extra gate when registration is enabled
# REGISTRATION_INVITE_CODE=your-secret-invite

# LLM cost protection (each receipt upload triggers one Gemini call)
LLM_SCANS_PER_USER_PER_DAY=10
LLM_SCANS_GLOBAL_PER_DAY=50
SCAN_RATE_LIMIT=5 per minute

# Dev-only password reset UI (disable on public servers)
ENABLE_DEV_PASSWORD_RESET=false

# Database (optional; default is SQLite in project root)
# DATABASE_URL=sqlite:///receipts.db

# Uploads
# UPLOAD_FOLDER=/var/lib/grocery_tracker/receipts
# MAX_CONTENT_LENGTH=10485760
